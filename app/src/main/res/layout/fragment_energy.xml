<?xml version="1.0" encoding="utf-8"?>
<!--
    Energy Dashboard — Diamond node area + extras cards below.
    Diamond (inside node_area ConstraintLayout, 420dp tall):
        [Grid]        top-center
        [Battery]     middle-left    [Solar]  middle-right
              [Home]  bottom-center

    EnergyFlowView is declared FIRST so it renders BELOW all node circles.
    Extras (gas, water, extra1-3) appear as MaterialCardView rows below the diamond.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/recyclerBackground">

    <!-- Loading indicator, shown while data is being fetched -->
    <TextView
        android:id="@+id/energy_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="@string/msg_please_wait"
        android:textSize="16sp"
        android:visibility="visible" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/energy_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/energy_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- Temperature — top-right, shown when sensor configured -->
            <LinearLayout
                android:id="@+id/temp_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@null"
                    android:src="@drawable/temperature"
                    app:tint="?attr/colorAccent" />

                <TextView
                    android:id="@+id/txt_temperature_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    tools:text="6.7 C, 91 %, 1026 hPa" />
            </LinearLayout>

            <!--
                Diamond node area — 420dp tall ConstraintLayout.
                EnergyFlowView is declared FIRST (renders behind circles).

                Node positions (exact, pixel-accurate):
                  Grid    : top-center       (H=0.5, V=0.0)
                  Battery : middle-left      (start=0, V=0.40)
                  Solar   : middle-right     (end=0,   V=0.40)
                  Home    : bottom-center    (H=0.5,   V=1.0)
            -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/node_area"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:layout_marginTop="4dp">

                <!-- ① Flow lines — drawn FIRST so they are BELOW the circles -->
                <nl.hnogames.domoticz.ui.EnergyFlowView
                    android:id="@+id/energy_flow_view"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:clickable="false"
                    android:focusable="false"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <!-- ② Grid / P1 — top-center -->
                <LinearLayout
                    android:id="@+id/card_p1"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:background="@drawable/energy_circle_cyan"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@null"
                        android:src="@drawable/factory_24px"
                        app:tint="@android:color/white" />

                    <TextView
                        android:id="@+id/txt_p1_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="4762 Watt" />

                    <TextView
                        android:id="@+id/txt_p1_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="@android:color/white"
                        android:textSize="9sp"
                        tools:text="→ 15535 kWh" />
                </LinearLayout>

                <!-- ③ Battery — middle-left -->
                <LinearLayout
                    android:id="@+id/card_battery"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:background="@drawable/energy_circle_green"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.40">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@null"
                        android:src="@drawable/battery_charging_90_24px"
                        app:tint="@android:color/white" />

                    <TextView
                        android:id="@+id/txt_battery_soc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@android:color/white"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        tools:text="99%" />

                    <TextView
                        android:id="@+id/txt_battery_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="@android:color/white"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        tools:text="0 Watt" />
                </LinearLayout>

                <!-- ④ Solar — middle-right -->
                <LinearLayout
                    android:id="@+id/card_solar"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:background="@drawable/energy_circle_yellow"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.40">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@null"
                        android:src="@drawable/solar_power_24px"
                        app:tint="@android:color/white" />

                    <TextView
                        android:id="@+id/txt_solar_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@android:color/white"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="289 Watt" />

                    <TextView
                        android:id="@+id/txt_solar_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="@android:color/white"
                        android:textSize="9sp"
                        tools:text="0.000 kWh" />
                </LinearLayout>

                <!-- ⑤ Home — bottom-center (larger, main hub) -->
                <LinearLayout
                    android:id="@+id/card_home"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:background="@drawable/energy_circle_pink"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintVertical_bias="1.0">

                    <ImageView
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:contentDescription="@null"
                        android:src="@drawable/house"
                        app:tint="@android:color/white" />

                    <TextView
                        android:id="@+id/txt_home_power"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@android:color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        tools:text="5051 Watt" />

                    <TextView
                        android:id="@+id/txt_home_total"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="@android:color/white"
                        android:textSize="9sp"
                        tools:text="15535.219" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
            <!-- end node_area -->

            <!-- ══════════════════════════════════════════════
                 Extras — 2-column MaterialCardView grid below diamond
                 ══════════════════════════════════════════════ -->
            <LinearLayout
                android:id="@+id/extras_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp">

                <!-- Row 1: Gas | Water -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_gas_wrapper"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:id="@+id/card_gas"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <ImageView
                                android:id="@+id/img_gas_icon"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:contentDescription="@null"
                                android:src="@drawable/mode_heat_24px" />

                            <TextView
                                android:id="@+id/txt_gas_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="0.000 m3" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_water_wrapper"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:id="@+id/card_water"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <ImageView
                                android:id="@+id/img_water_icon"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:contentDescription="@null"
                                android:src="@drawable/drop" />

                            <TextView
                                android:id="@+id/txt_water_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="30 Liter" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 2: Extra1 | Extra2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_extra1_wrapper"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:id="@+id/card_extra1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <ImageView
                                android:id="@+id/img_extra1_icon"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:contentDescription="@null"
                                android:src="@drawable/heater" />

                            <TextView
                                android:id="@+id/txt_extra1_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="776 Watt" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_extra2_wrapper"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:id="@+id/card_extra2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <ImageView
                                android:id="@+id/img_extra2_icon"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:contentDescription="@null"
                                android:src="@drawable/car" />

                            <TextView
                                android:id="@+id/txt_extra2_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="4101 Watt" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>
                </LinearLayout>

                <!-- Row 3: Extra3 | (empty) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="4dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_extra3_wrapper"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:visibility="gone"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="2dp">

                        <LinearLayout
                            android:id="@+id/card_extra3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="14dp">

                            <ImageView
                                android:id="@+id/img_extra3_icon"
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:contentDescription="@null"
                                android:src="@drawable/factory_24px" />

                            <TextView
                                android:id="@+id/txt_extra3_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="--" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- empty right half to keep grid balanced -->
                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />
                </LinearLayout>

            </LinearLayout>
            <!-- end extras_container -->

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>

