<?xml version="1.0" encoding="utf-8"?>
<!--
    Landscape energy dashboard — Diamond + extras below (mirrors portrait).
    Diamond (420dp wide ConstraintLayout, full screen height):
        [Grid]    top-center
        [Bat]     mid-left     [Solar]  mid-right
              [Home]  bottom-center
    Extras as 2-col card grid below the diamond (scrollable).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/recyclerBackground">

    <TextView
        android:id="@+id/energy_loading"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="@string/msg_please_wait"
        android:textSize="16sp"
        android:visibility="visible" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/energy_scroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/energy_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp">

            <!-- Left: diamond node area (fixed width so lines stay correct) -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/node_area"
                android:layout_width="0dp"
                android:layout_height="320dp"
                android:layout_weight="1">

                <!-- ① Flow lines — FIRST so they render BELOW circles -->
                <nl.hnogames.domoticz.ui.EnergyFlowView
                    android:id="@+id/energy_flow_view"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:clickable="false"
                    android:focusable="false"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <!-- Grid — top-center -->
                <LinearLayout
                    android:id="@+id/card_p1"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/energy_circle_cyan"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:visibility="invisible"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.0">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@drawable/factory_24px" app:tint="@android:color/white" />
                    <TextView android:id="@+id/txt_p1_value"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold"
                        tools:text="4762 Watt" />
                    <TextView android:id="@+id/txt_p1_info"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="@android:color/white" android:textSize="9sp"
                        tools:text="→ 15535 kWh" />
                </LinearLayout>

                <!-- Battery — middle-left -->
                <LinearLayout
                    android:id="@+id/card_battery"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/energy_circle_green"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.40">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@drawable/battery_charging_90_24px" app:tint="@android:color/white" />
                    <TextView android:id="@+id/txt_battery_soc"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@android:color/white" android:textSize="14sp" android:textStyle="bold"
                        tools:text="99%" />
                    <TextView android:id="@+id/txt_battery_value"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="@android:color/white" android:textSize="10sp" android:textStyle="bold"
                        tools:text="0 Watt" />
                </LinearLayout>

                <!-- Solar — middle-right -->
                <LinearLayout
                    android:id="@+id/card_solar"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/energy_circle_yellow"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp"
                    android:visibility="invisible"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.40">
                    <ImageView android:layout_width="22dp" android:layout_height="22dp"
                        android:contentDescription="@null"
                        android:src="@drawable/solar_power_24px" app:tint="@android:color/white" />
                    <TextView android:id="@+id/txt_solar_value"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@android:color/white" android:textSize="12sp" android:textStyle="bold"
                        tools:text="289 Watt" />
                    <TextView android:id="@+id/txt_solar_info"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="@android:color/white" android:textSize="9sp"
                        tools:text="0.000 kWh" />
                </LinearLayout>

                <!-- Home — bottom-center -->
                <LinearLayout
                    android:id="@+id/card_home"
                    android:layout_width="108dp"
                    android:layout_height="108dp"
                    android:background="@drawable/energy_circle_pink"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="10dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintVertical_bias="1.0">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp"
                        android:contentDescription="@null"
                        android:src="@drawable/house" app:tint="@android:color/white" />
                    <TextView android:id="@+id/txt_home_power"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:textColor="@android:color/white" android:textSize="14sp" android:textStyle="bold"
                        tools:text="5051 Watt" />
                    <TextView android:id="@+id/txt_home_total"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="1dp"
                        android:textColor="@android:color/white" android:textSize="9sp"
                        tools:text="15535 kWh" />
                </LinearLayout>

                <!-- Temperature — top-right corner of diamond -->
                <LinearLayout
                    android:id="@+id/temp_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">
                    <ImageView android:layout_width="18dp" android:layout_height="18dp"
                        android:contentDescription="@null"
                        android:src="@drawable/temperature" app:tint="?attr/colorAccent" />
                    <TextView android:id="@+id/txt_temperature_value"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:textSize="12sp" android:textStyle="bold"
                        tools:text="7.3 °C" />
                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Right: extras as a vertical card stack -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:layout_marginStart="8dp"
                android:gravity="top">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_gas_wrapper"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:id="@+id/card_gas"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
                        <ImageView android:id="@+id/img_gas_icon"
                            android:layout_width="24dp" android:layout_height="24dp"
                            android:contentDescription="@null" android:src="@drawable/mode_heat_24px" />
                        <TextView android:id="@+id/txt_gas_value"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textSize="13sp" android:textStyle="bold" tools:text="0.457 m3" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_water_wrapper"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:id="@+id/card_water"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
                        <ImageView android:id="@+id/img_water_icon"
                            android:layout_width="24dp" android:layout_height="24dp"
                            android:contentDescription="@null" android:src="@drawable/drop" />
                        <TextView android:id="@+id/txt_water_value"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textSize="13sp" android:textStyle="bold" tools:text="150 Liter" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_extra1_wrapper"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:id="@+id/card_extra1"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
                        <ImageView android:id="@+id/img_extra1_icon"
                            android:layout_width="24dp" android:layout_height="24dp"
                            android:contentDescription="@null" android:src="@drawable/heater" />
                        <TextView android:id="@+id/txt_extra1_value"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textSize="13sp" android:textStyle="bold" tools:text="503 Watt" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_extra2_wrapper"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:id="@+id/card_extra2"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
                        <ImageView android:id="@+id/img_extra2_icon"
                            android:layout_width="24dp" android:layout_height="24dp"
                            android:contentDescription="@null" android:src="@drawable/car" />
                        <TextView android:id="@+id/txt_extra2_value"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textSize="13sp" android:textStyle="bold" tools:text="4124 Watt" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_extra3_wrapper"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="2dp">
                    <LinearLayout android:id="@+id/card_extra3"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">
                        <ImageView android:id="@+id/img_extra3_icon"
                            android:layout_width="24dp" android:layout_height="24dp"
                            android:contentDescription="@null" android:src="@drawable/factory_24px" />
                        <TextView android:id="@+id/txt_extra3_value"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:textSize="13sp" android:textStyle="bold" tools:text="--" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</FrameLayout>

