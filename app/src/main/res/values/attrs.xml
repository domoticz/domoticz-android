<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="TemplateView">
        <attr name="gnt_template_type" format="reference" />
    </declare-styleable>

    <attr name="lockedValues" format="reference" />
    <attr name="lockedValuesDependencyKeys" format="reference" />
    <attr name="dynamicEntriesProvider" format="string" />
    <attr name="dynamicEntryValuesProvider" format="string" />
    <attr name="selectAllValuesByDefault" format="boolean" />

    <attr name="recyclerBackground" format="color" />
    <attr name="listviewBackground" format="color" />
    <attr name="listviewRowBackground" format="color" />
    <attr name="listviewRowTintBackground" format="color" />
    <attr name="backdropBackground" format="color" />
    <attr name="buttonTextColor" format="color" />
    <attr name="toolbarBackground" format="color" />
    <attr name="toolbarTextColor" format="color" />
    <attr name="graphTextColor" format="color" />
    <attr name="wizardCardColor" format="color" />
    <attr name="wizardTitleColor" format="color" />
    <attr name="temperatureTextColor" format="color" />
    <attr name="preferenceIconColor" format="color" />
    <attr name="incomingDefaultBubbleColor" format="color" />
    <attr name="incomingTextColor" format="color" />
    <attr name="outcomingDefaultBubbleColor" format="color" />
    <attr name="outcomingTextColor" format="color" />
    <!-- Missing bubble color attrs needed by chat layouts -->
    <attr name="incomingDefaultBubblePressedColor" format="color" />
    <attr name="incomingDefaultBubbleSelectedColor" format="color" />
    <attr name="outcomingDefaultBubblePressedColor" format="color" />
    <attr name="outcomingDefaultBubbleSelectedColor" format="color" />
    <attr name="editTextBackgroundColor" format="color" />
    <attr name="editTextTextColor" format="color" />
    <attr name="floatingActionBar" format="color" />
    <attr name="floatingActionBarText" format="color" />
    <attr name="highlightColor" format="color" />

    <declare-styleable name="CustomListPreference">
        <attr name="lockedValues" />
        <attr name="lockedValuesDependencyKeys" />
        <attr name="selectAllValuesByDefault" />
        <attr name="dynamicEntriesProvider" />
        <attr name="dynamicEntryValuesProvider" />
    </declare-styleable>

    <declare-styleable name="BackdropContainer">
        <attr name="menuIcon" format="reference" />
        <attr name="closeIcon" format="reference" />
        <attr name="duration" format="integer" />
    </declare-styleable>
</resources>